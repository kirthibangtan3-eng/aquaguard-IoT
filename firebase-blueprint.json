{
  "entities": {
    "Sensor": {
      "title": "Sensor Node",
      "description": "A pipeline monitoring sensor node",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "status": { "type": "string", "enum": ["flowing", "no-flow", "offline"] },
        "lastUpdate": { "type": "string", "format": "date-time" },
        "battery": { "type": "number" },
        "section": { "type": "string" }
      },
      "required": ["id", "location", "status"]
    },
    "FlowReading": {
      "title": "Flow Reading",
      "description": "Periodic flow data from a sensor",
      "type": "object",
      "properties": {
        "sensorId": { "type": "string" },
        "flowRate": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["sensorId", "flowRate", "timestamp"]
    },
    "Alert": {
      "title": "Alert",
      "description": "System generated alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sensorId": { "type": "string" },
        "type": { "type": "string", "enum": ["no-flow", "predictive-maintenance", "offline"] },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "message": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "resolved": { "type": "boolean" }
      },
      "required": ["sensorId", "type", "message", "timestamp"]
    }
  },
  "firestore": {
    "/sensors/{sensorId}": {
      "schema": "Sensor",
      "description": "Collection of pipeline sensors"
    },
    "/sensors/{sensorId}/readings/{readingId}": {
      "schema": "FlowReading",
      "description": "Historical flow readings for a sensor"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "System alerts"
    }
  }
}
